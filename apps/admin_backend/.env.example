NODE_ENV=development
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=omnifood
DB_USERNAME=postgres
DB_PASSWORD=change-me
# Development-only value. It is rejected when NODE_ENV=production; replace it
# with a unique managed secret before deployment.
JWT_SECRET=development-only-jwt-secret-at-least-thirty-two-bytes
JWT_ISSUER=omnifood-admin
JWT_AUDIENCE=omnifood-pos
JWT_ACCESS_TTL_SECONDS=3600
JWT_REFRESH_TTL_SECONDS=604800
JWT_CLOCK_TOLERANCE_SECONDS=5
JWT_ALGORITHM=HS256
